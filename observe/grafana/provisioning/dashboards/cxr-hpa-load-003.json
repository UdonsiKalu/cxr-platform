{
  "title": "CXR HPA Load (LOAD-003 / OBS-001)",
  "uid": "cxr-hpa-load-003",
  "tags": ["cxr", "hpa", "load-003", "obs-001"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "type": "text",
      "title": "Live load test",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "**Live:** `./scripts/23-k8-load-observe-up.sh` · Locust **:8092** → K8 **:8081** · Jaeger **cxr-analyzer-service** · CSV still via `run-k8-load-with-metrics.sh`"
      }
    },
    {
      "type": "timeseries",
      "title": "HPA current replicas (cxr-ui namespace)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"cxr-ui\"}",
          "legendFormat": "{{horizontalpodautoscaler}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "HPA max replicas (spec)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_spec_max_replicas{namespace=\"cxr-ui\"}",
          "legendFormat": "{{horizontalpodautoscaler}} max"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Deployment replicas available",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_available{namespace=\"cxr-ui\", deployment=~\"cxr-analyzer|cxr-ui\"}",
          "legendFormat": "{{deployment}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Pending pods",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(kube_pod_status_phase{namespace=\"cxr-ui\", phase=\"Pending\"})",
          "legendFormat": "pending"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Prometheus scrape health",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "up{job=\"kube-state-metrics\"}", "legendFormat": "kube-state-metrics" },
        { "expr": "up{job=\"prometheus\"}", "legendFormat": "prometheus" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "max": 1, "min": 0 }, "overrides": [] }
    }
  ]
}
