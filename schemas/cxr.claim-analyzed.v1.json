{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CXR claim analyzed event",
  "type": "object",
  "required": ["event", "claim_id", "status", "ts"],
  "properties": {
    "event": { "const": "claim.analyzed" },
    "claim_id": { "type": "string" },
    "status": { "type": "string" },
    "ts": { "type": "string", "format": "date-time" }
  }
}
