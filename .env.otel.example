# SW.11 OpenTelemetry — copy lines into rehearsal shell or .env.compose.local
# Start observe stack first: ./scripts/07-observe-up.sh

# Rehearsal dev (:8251) on Linux host
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_SERVICE_NAME=cxr-ui-rehearsal

# Compose :3000 on Docker Desktop (bridge)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318
# OTEL_SERVICE_NAME=cxr-ui-compose

# Compose :3000 with compose.host.yaml (host network)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# Disable without removing packages
# OTEL_SDK_DISABLED=true
