# Copy to .env.compose.local (gitignored). Used by compose.yaml via env_file.
# Match rehearsal :8251 — see cxr-ui-prune-rehearsal/cxr-ui/.env.local

# --- Secrets (required for SQL + optional admin) ---
CXR_SQL_PWD=your-sa-password
# CXR_ADMIN_TOKEN=dev-admin-token

# --- SQL (host network: 127.0.0.1; bridge: use host.docker.internal) ---
CXR_SQL_SERVER=127.0.0.1,1433
CXR_SQL_UID=SA
CXR_TERMINAL_DB=_claims
CXR_ARCHETYPE_DB=_archetype
CXR_DATA_SOURCE=db

# --- Qdrant (host overlay sets QDRANT_URL in compose.host.yaml) ---
# QDRANT_API_KEY=

# --- Spawn scripts (set in compose.yaml; override only if needed) ---
# CXR_ANALYZER_SCRIPT=/analyzers/analyze_sample.py
# CXR_JUDGE_SCRIPT=/analyzers/judge_claim.py
# CXR_EXAMPLES_FOLDER=/analyzers/examples

# --- LLM judge (host Ollama on :11434 when using compose.host.yaml) ---
CXR_JUDGE_BACKEND=ollama
CXR_JUDGE_MODEL=llama3:8b-instruct-q4_0
OLLAMA_HOST=http://127.0.0.1:11434

# --- Optional host services (sandbox stack) ---
CXR_GATEWAY_URL=http://127.0.0.1:8181
CXR_API_BASE=http://127.0.0.1:8281

# --- SW.11 OpenTelemetry (see .env.otel.example; copy when observe stack is up) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318
# OTEL_SERVICE_NAME=cxr-ui-compose

# --- Atlas + docs (paths use /staging mount from compose.host.yaml) ---
# CXR_ATLAS_STAGING_ROOT=/staging
# CXR_ATLAS_VAULT_META=/staging/cxr_architecture_vault/CXR-Meta
# CXR_DOCS_LIBRARY_ROOT=/staging/cxrlabs-dev/claim_analysis_tools/platform/docs/library
